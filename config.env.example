# ── HuggingFace Token ─────────────────────────────────────────────────────────
# Required for gated models (LLaMA-3, Gemma-2).
# Get yours at https://huggingface.co/settings/tokens
# You can also put it in a file called 'hf_token' in the project root.
HF_TOKEN=

# ── Email Report ──────────────────────────────────────────────────────────────
# Where to send the final benchmark report.
EMAIL_TO=your@email.com
EMAIL_FROM=gpu-bench@localhost

# ── SMTP Server ───────────────────────────────────────────────────────────────
# Gmail:    smtp.gmail.com   port 587  (use an App Password)
# Outlook:  smtp.office365.com  port 587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_NO_TLS=false

# ── Benchmark Defaults ────────────────────────────────────────────────────────
# Max tokens to generate per inference test
MAX_NEW_TOKENS=200

# Which model families to run by default (space-separated)
# Options: opt qwen phi mistral deepseek glm olmo kimi llama gemma
# Leave blank to run ALL families (needs ~500+ GB disk and many hours)
DEFAULT_FAMILIES=opt qwen mistral deepseek
